# Expresso ICE Server Environment Variables
# Copy this file to .env and update the values

# Server Configuration
TURN_EXTERNAL_IP=YOUR_EC2_ELASTIC_IP_HERE
TURN_REALM=expresso.com
TURN_SERVER_NAME=expresso_turn_server

# Authentication
TURN_USERNAME=expresso_user
TURN_PASSWORD=expresso_password
TURN_SECRET=your_turn_secret_key_here
TURN_STATIC_AUTH_SECRET=your_static_auth_secret_here

# Ports
TURN_LISTENING_PORT=3478
TURN_TLS_LISTENING_PORT=5349
TURN_MIN_PORT=49152
TURN_MAX_PORT=65535

# Security
TURN_NO_TLS=true
TURN_NO_DTLS=true
TURN_VERBOSE=true
TURN_DEBUG=true

# Bandwidth and Quota
TURN_USER_QUOTA=12
TURN_TOTAL_QUOTA=1200
TURN_MAX_BPS=500000
TURN_BPS_CAPACITY=0

# Session
TURN_STALE_NONCE=600 